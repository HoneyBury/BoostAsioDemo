{
  "title": "Boost Gateway v2.0",
  "uid": "boost-gateway",
  "panels": [
    {
      "title": "Active Sessions",
      "type": "gauge",
      "targets": [{ "expr": "gateway_active_sessions" }],
      "fieldConfig": { "defaults": { "max": 10000 } }
    },
    {
      "title": "Authenticated Sessions",
      "type": "gauge",
      "targets": [{ "expr": "gateway_authenticated_sessions" }]
    },
    {
      "title": "Active Rooms",
      "type": "stat",
      "targets": [{ "expr": "gateway_active_rooms" }]
    },
    {
      "title": "Active Battles",
      "type": "stat",
      "targets": [{ "expr": "gateway_active_battles" }]
    },
    {
      "title": "Packets Received / sec",
      "type": "timeseries",
      "targets": [{ "expr": "rate(gateway_packets_received_total[1m])", "legendFormat": "recv/s" }]
    },
    {
      "title": "Packets Sent / sec",
      "type": "timeseries",
      "targets": [{ "expr": "rate(gateway_packets_sent_total[1m])", "legendFormat": "sent/s" }]
    },
    {
      "title": "Bytes Received / sec",
      "type": "timeseries",
      "targets": [{ "expr": "rate(gateway_bytes_received_total[1m])", "legendFormat": "recv B/s" }]
    },
    {
      "title": "Bytes Sent / sec",
      "type": "timeseries",
      "targets": [{ "expr": "rate(gateway_bytes_sent_total[1m])", "legendFormat": "sent B/s" }]
    },
    {
      "title": "Blocked Packets / sec",
      "type": "timeseries",
      "targets": [{ "expr": "rate(gateway_packets_blocked_total[1m])", "legendFormat": "blocked/s" }]
    },
    {
      "title": "Login Success / sec",
      "type": "timeseries",
      "targets": [{ "expr": "rate(gateway_login_success_total[1m])", "legendFormat": "logins/s" }]
    },
    {
      "title": "Sessions Accepted Rate",
      "type": "timeseries",
      "targets": [{ "expr": "gateway_sessions_accepted_rate", "legendFormat": "accept/s" }]
    },
    {
      "title": "Gateway Health",
      "type": "stat",
      "targets": [{ "expr": "up"}]
    },

    {
      "title": "Backend Instances (Login)",
      "type": "stat",
      "targets": [
        { "expr": "backend_login_healthy_instances", "legendFormat": "healthy" },
        { "expr": "backend_login_unhealthy_instances", "legendFormat": "unhealthy" }
      ]
    },
    {
      "title": "Backend Instances (Room)",
      "type": "stat",
      "targets": [
        { "expr": "backend_room_healthy_instances", "legendFormat": "healthy" },
        { "expr": "backend_room_unhealthy_instances", "legendFormat": "unhealthy" }
      ]
    },
    {
      "title": "Backend Instances (Battle)",
      "type": "stat",
      "targets": [
        { "expr": "backend_battle_healthy_instances", "legendFormat": "healthy" },
        { "expr": "backend_battle_unhealthy_instances", "legendFormat": "unhealthy" }
      ]
    },
    {
      "title": "Backend Route Requests / sec",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(backend_route_requests_total[1m])", "legendFormat": "requests/s" },
        { "expr": "rate(backend_route_successes_total[1m])", "legendFormat": "successes/s" }
      ]
    },
    {
      "title": "Backend Route Errors / sec",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(backend_route_errors_total[1m])", "legendFormat": "errors/s" },
        { "expr": "rate(backend_route_timeouts_total[1m])", "legendFormat": "timeouts/s" }
      ]
    },
    {
      "title": "Backend Route Latency (p50/p99)",
      "type": "timeseries",
      "targets": [
        { "expr": "backend_route_latency_ms", "legendFormat": "p50" },
        { "expr": "backend_route_latency_ms{quantile=\"0.99\"}", "legendFormat": "p99" }
      ]
    }
  ]
}
